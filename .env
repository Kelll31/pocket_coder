# Версии образов
OLLAMA_IMAGE=ollama/ollama:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest

# Порт для Ollama
OLLAMA_PORT=11434

# Порт для LiteLLM
LITELLM_PORT=4000

# Модели для Plan/Act архитектуры
PLAN_MODEL=deepseek-r1:14b
ACT_MODEL=qwen2.5-coder:14b

# Настройки генерации кода
DEFAULT_MAX_TOKENS=32768
REQUEST_TIMEOUT=1200
TEMPERATURE_PLAN=0.3
TEMPERATURE_ACT=0.8

# Дополнительные настройки (опционально)
# OLLAMA_KEEP_ALIVE=24h
# LITELLM_LOG=DEBUG
